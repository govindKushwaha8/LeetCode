class Solution {
public:
    bool containsNearbyAlmostDuplicate(vector<int>& nums, int indexDiff, int valueDiff) {
        set<long long> window;  // use long long to avoid overflow

        for (int i = 0; i < nums.size(); i++) {
            // Maintain window size
            if (i > indexDiff) {
                window.erase(nums[i - indexDiff - 1]);
            }

            // Find smallest number >= nums[i] - valueDiff
            auto it = window.lower_bound((long long)nums[i] - valueDiff);

            // Check if it satisfies valueDiff condition
            if (it != window.end() && abs(*it - nums[i]) <= valueDiff) {
                return true;
            }

            // Insert current element
            window.insert(nums[i]);
        }
        return false;
    }
};
