class Solution {
public:
    vector<int> scoreValidator(vector<string>& events) {
        int score = 0;
        int counter = 0;

        for (string &e : events) {
            if (counter == 10) break;

            if (e == "W") {
                counter++;
            }
            else if (e == "WD" || e == "NB") {
                score += 1;
            }
            else {
                score += stoi(e);
            }
        }

        return {score, counter};
    }
};
