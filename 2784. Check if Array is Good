class Solution {
public:
    bool isGood(vector<int>& nums) {
        sort(nums.begin(), nums.end());

        int n = nums.size();

        // Check numbers from 1 to n-1
        for (int i = 0; i < n - 1; i++) {
            if (nums[i] != i + 1)
                return false;
        }

        // Last element should also be n-1
        return nums[n - 1] == n - 1;
    }
};
