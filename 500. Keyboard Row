class Solution {
public:
    vector<string> findWords(vector<string>& words) {
        string row1 = "qwertyuiop";
        string row2 = "asdfghjkl";
        string row3 = "zxcvbnm";

        vector<string> ans;

        for (string word : words) {
            string lower = "";

            // convert to lowercase
            for (char ch : word) {
                lower += tolower(ch);
            }

            int row = 0;

            // decide starting row
            if (row1.find(lower[0]) != string::npos)
                row = 1;
            else if (row2.find(lower[0]) != string::npos)
                row = 2;
            else
                row = 3;

            bool ok = true;

            // check all characters
            for (char ch : lower) {
                if (row == 1 && row1.find(ch) == string::npos)
                    ok = false;

                if (row == 2 && row2.find(ch) == string::npos)
                    ok = false;

                if (row == 3 && row3.find(ch) == string::npos)
                    ok = false;
            }

            if (ok)
                ans.push_back(word);
        }

        return ans;
    }
};
