class Solution {
public:
    string reformat(string s) {
        string a, d;
        for (char c : s)
            isdigit(c) ? d += c : a += c;

        if (abs((int)a.size() - (int)d.size()) > 1) return "";

        string ans;
        bool letter = a.size() >= d.size();

        while (!a.empty() || !d.empty()) {
            if (letter) ans += a[0], a.erase(a.begin());
            else ans += d[0], d.erase(d.begin());
            letter = !letter;
        }
        return ans;
    }
};
