class Solution {
public:
    int rows, cols, total;
    unordered_map<int, int> mp;

    Solution(int m, int n) {
        rows = m;
        cols = n;
        total = m * n;
    }
    
    vector<int> flip() {
        int r = rand() % total;
        total--;

        int x = mp.count(r) ? mp[r] : r;

        mp[r] = mp.count(total) ? mp[total] : total;

        return {x / cols, x % cols};
    }
    
    void reset() {
        mp.clear();
        total = rows * cols;
    }
};
