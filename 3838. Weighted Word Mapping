class Solution {
public:
    string weightedWordMapping(vector<string>& words, vector<int>& weights) {
        string ans = "";

        for (string word : words) {
            int sum = 0;

            for (char ch : word) {
                sum += weights[ch - 'a'];
            }

            int rem = sum % 26;

            // 0 -> z, 1 -> y, ..., 25 -> a
            char mapped = 'z' - rem;

            ans += mapped;
        }

        return ans;
    }
};
