class Solution {
public:
    bool isIsomorphic(string s, string t) {
        unordered_map<char, char> m1; // s -> t
        unordered_map<char, char> m2; // t -> s
        
        for (int i = 0; i < s.length(); i++) {
            char c1 = s[i];
            char c2 = t[i];
            
            // Check s -> t mapping
            if (m1.count(c1)) {
                if (m1[c1] != c2)
                    return false;
            } else {
                m1[c1] = c2;
            }
            
            // Check t -> s mapping
            if (m2.count(c2)) {
                if (m2[c2] != c1)
                    return false;
            } else {
                m2[c2] = c1;
            }
        }
        
        return true;
    }
};
