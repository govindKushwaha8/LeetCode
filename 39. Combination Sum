class Solution {
public:
    vector<vector<int>> ans;
    
    void dfs(int i, int target, vector<int>& c, vector<int>& cur) {
        if (target == 0) {
            ans.push_back(cur);
            return;
        }
        if (i == c.size() || target < 0) return;

        // pick
        cur.push_back(c[i]);
        dfs(i, target - c[i], c, cur);
        cur.pop_back();

        // skip
        dfs(i + 1, target, c, cur);
    }

    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<int> cur;
        dfs(0, target, candidates, cur);
        return ans;
    }
};
