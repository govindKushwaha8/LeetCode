class Solution {
public:
    string smallestGoodBase(string n) {
        long long num = stoll(n);
        int max_m = log2(num);

        for (int m = max_m; m >= 1; m--) {
            long long left = 2;
            long long right = pow(num, 1.0 / m);

            while (left <= right) {
                long long mid = (left + right) / 2;
                __int128 sum = 1, cur = 1;

                for (int i = 1; i <= m; i++) {
                    cur *= mid;
                    sum += cur;
                }

                if (sum == num)
                    return to_string(mid);
                else if (sum < num)
                    left = mid + 1;
                else
                    right = mid - 1;
            }
        }

        return to_string(num - 1);
    }
};
