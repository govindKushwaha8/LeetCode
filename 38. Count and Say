class Solution {
public:
    string countAndSay(int n) {
        string s = "1";
        for (int i = 2; i <= n; i++) {
            string t = "";
            for (int j = 0; j < s.size(); ) {
                int cnt = 1;
                while (j + cnt < s.size() && s[j] == s[j + cnt]) cnt++;
                t += to_string(cnt) + s[j];
                j += cnt;
            }
            s = t;
        }
        return s;
    }
};
