class Solution {
public:
    bool isPrefixAndSuffix(string s1, string s2) {
        int n = s1.size();
        int m = s2.size();

        if (n > m) return false;

        // Check prefix
        if (s2.substr(0, n) != s1) return false;

        // Check suffix
        if (s2.substr(m - n, n) != s1) return false;

        return true;
    }

    int countPrefixSuffixPairs(vector<string>& words) {
        int count = 0;
        int n = words.size();

        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {
                if (isPrefixAndSuffix(words[i], words[j])) {
                    count++;
                }
            }
        }

        return count;
    }
};
